# Runtime mode. Production refuses seed-backed operational routes until durable repositories replace them.
NODE_ENV="development"
DEMO_MODE="true"
AI_DEMO_MODE="true"
NEXT_PUBLIC_DEMO_MODE="true"

PORT="4000"
CORS_ALLOWED_ORIGINS="http://localhost:3000"

DATABASE_URL="postgresql://african_guard:change-me@localhost:5432/african_guard?schema=public"
REDIS_URL="redis://localhost:6379"
KAFKA_BROKERS="localhost:9092"
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="change-me"
AI_SERVICE_URL="http://localhost:8001"
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_WS_URL="http://localhost:4000"

# OIDC configuration for real users.
OAUTH_ISSUER_URL="https://identity.example.invalid"
OAUTH_AUDIENCE="african-guard-api"
OAUTH_JWKS_URL=""
OAUTH_ALLOWED_ALGORITHMS="RS256"
OAUTH_CLOCK_SKEW_SECONDS="60"
OAUTH_HTTP_TIMEOUT_MS="5000"
OAUTH_JWKS_CACHE_MS="300000"
MFA_REQUIRED="true"

# Explicit local-only bearer authentication. Never enable this in production.
ALLOW_DEV_AUTH="true"
DEV_BEARER_TOKEN="replace-with-a-long-random-local-token"
DEV_TENANT_ID="tenant-afribank"
DEV_USER_ID="local-developer"
DEV_USER_ROLES="admin,developer,fraud_investigator,compliance_officer,auditor,analyst"
DEV_USER_SCOPES="transactions.read transactions.write cases.read cases.write"

# 32 random bytes encoded as base64. Supply through a managed secret system in production.
ENCRYPTION_MASTER_KEY=""
ENCRYPTION_KEY_REF="vault://african-guard/keys/application/current"

# Webhook request signing. Prefer an integration-specific variable such as
# WEBHOOK_SIGNING_SECRET_INT_AFRIBANK_OPENBANKING.
WEBHOOK_SIGNING_SECRET="replace-with-at-least-32-random-characters"
WEBHOOK_CLOCK_SKEW_SECONDS="300"
REDIS_CONNECT_TIMEOUT_MS="3000"

# Approved AI artifact configuration. Required in production.
MODEL_ARTIFACT_PATH=""
MODEL_ARTIFACT_SHA256=""

OPEN_BANKING_DIRECTORY_URL="https://openbanking.example.invalid"
PAYMENT_NETWORK_SANDBOX="true"
AUDIT_EXPORT_BUCKET="s3://replace-with-secure-bucket"
